---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
---

<BaseLayout title="FILE NOT FOUND — TRACED" description="This case file does not exist in the archive.">
  <Nav currentPath="/" />

  <main class="nf-page">
    <div class="nf-container">

      <div class="nf-code-wrap">
        <span class="nf-code">404</span>
        <div class="nf-code-label">FILE NOT FOUND</div>
      </div>

      <div class="nf-divider" />

      <div class="nf-content">
        <div class="nf-eyebrow">CASE FILE ERROR</div>
        <h1 class="nf-headline">RECORD DOES NOT EXIST</h1>
        <p class="nf-body">
          The file you requested is not in the archive. It may have been redacted,
          moved, or never existed. All active case files are accessible from the main archive.
        </p>

        <div class="nf-actions">
          <a href="/" class="nf-btn nf-btn-primary">RETURN TO ARCHIVE</a>
          <a href="/check" class="nf-btn nf-btn-ghost">PASSWORD CHECK</a>
        </div>
      </div>

      <div class="nf-terminal">
        <div class="nf-term-line">
          <span class="nf-prompt">TRACED</span>
          <span class="nf-cmd">$ lookup --case <span class="nf-arg">[REDACTED]</span></span>
        </div>
        <div class="nf-term-line nf-err">✗ ERROR: No matching record in breach database</div>
        <div class="nf-term-line nf-muted">→ Cross-referencing secondary index... <span class="nf-fail">FAILED</span></div>
        <div class="nf-term-line nf-muted">→ Checking cold storage... <span class="nf-fail">FAILED</span></div>
        <div class="nf-term-line nf-muted">→ Querying HIBP relay... <span class="nf-fail">FAILED</span></div>
        <div class="nf-term-line nf-warn">⚠ FILE NOT LOCATED IN ANY KNOWN INDEX</div>
        <div class="nf-term-cursor">_</div>
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  .nf-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .nf-container {
    max-width: 640px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nf-code-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nf-code {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 20vw, 9rem);
    letter-spacing: 0.08em;
    color: var(--color-danger);
    line-height: 0.9;
    opacity: 0.15;
  }

  .nf-code-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.35em;
    color: var(--color-danger);
    opacity: 0.6;
  }

  .nf-divider {
    height: 1px;
    background: var(--color-border);
  }

  .nf-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .nf-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    color: var(--color-accent);
    opacity: 0.7;
  }

  .nf-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    letter-spacing: 0.1em;
    color: var(--color-text);
    margin: 0;
    line-height: 1;
  }

  .nf-body {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin: 0;
    max-width: 480px;
  }

  .nf-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .nf-btn {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    padding: 9px 20px;
    border: 1px solid;
    transition: all 0.15s;
    border-radius: 2px;
  }

  .nf-btn-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .nf-btn-primary:hover { background: #2563eb; border-color: #2563eb; }

  .nf-btn-ghost {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-muted);
  }

  .nf-btn-ghost:hover { border-color: var(--color-muted); color: var(--color-text); }

  .nf-terminal {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .nf-term-line {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
  }

  .nf-prompt {
    color: var(--color-accent);
    font-weight: 600;
    flex-shrink: 0;
  }

  .nf-cmd { color: var(--color-text); opacity: 0.7; }
  .nf-arg { color: var(--color-danger); opacity: 0.8; }

  .nf-err { color: var(--color-danger); opacity: 0.8; }
  .nf-warn { color: #f59e0b; opacity: 0.8; font-size: 0.62rem; margin-top: 2px; }
  .nf-muted { color: var(--color-muted); opacity: 0.6; padding-left: 0; }
  .nf-fail { color: var(--color-danger); opacity: 0.9; }

  .nf-term-cursor {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    animation: blink 1s step-end infinite;
    margin-top: 4px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (max-width: 640px) {
    .nf-page { padding: 3rem 1rem; }
  }
</style>
