---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import { getAllBreaches } from '../lib/hibp'
import { getTotalPwnCount, getAllDataClasses, getBreachStatus } from '../lib/utils'
import { TimelineScrubber } from '../components/TimelineScrubber'
import { BreachArchive } from '../components/BreachArchive'
import FieldBriefing from '../components/FieldBriefing.astro'

const breaches = await getAllBreaches()
const totalPwned = getTotalPwnCount(breaches)
const totalDataClasses = getAllDataClasses(breaches).length
const criticalCount = breaches.filter((b) => getBreachStatus(b) === 'CRITICAL').length

function formatBigNumber(n: number): string {
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B'
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(0) + 'M'
  return n.toLocaleString()
}
---

<BaseLayout title="TRACED — Every Breach. Every Record." description="Browse every known data breach as a case file. Check if your password has been compromised.">
  <Nav currentPath="/" />

  <main>
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">Data Breach Case Files</div>
        <h1 class="hero-title">TRACED</h1>
        <p class="hero-tagline">EVERY BREACH. EVERY RECORD. FULLY EXPOSED.</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value" data-count={breaches.length}>{breaches.length}</span>
            <span class="stat-label">CASES ON FILE</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value" data-count={totalPwned} data-count-format="big">{formatBigNumber(totalPwned)}</span>
            <span class="stat-label">ACCOUNTS COMPROMISED</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value" data-count={totalDataClasses}>{totalDataClasses}</span>
            <span class="stat-label">DATA TYPES STOLEN</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value critical-val" data-count={criticalCount}>{criticalCount}</span>
            <span class="stat-label">CRITICAL</span>
          </div>
        </div>

        <div class="hero-cta-row">
          <a href="#archive" class="hero-cta">VIEW ALL CASES ↓</a>
          <a href="/check" class="hero-cta hero-cta-ghost">CHECK PASSWORD →</a>
        </div>
      </div>

      <div class="hero-grid-bg" aria-hidden="true">
        {Array.from({ length: 80 }).map(() => (
          <div class="grid-cell" />
        ))}
      </div>
    </section>

    <FieldBriefing breachCount={breaches.length} criticalCount={criticalCount} />

    <TimelineScrubber client:visible />

    <section id="archive" aria-labelledby="archive-heading">
      <h2 id="archive-heading" class="sr-only">Breach Archive</h2>
      <BreachArchive client:visible />
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-left">
        <span class="footer-wordmark">TRACED</span>
        <span class="footer-tagline">Data Breach Case Files</span>
      </div>
      <div class="footer-center">
        <span class="footer-stat">{breaches.length} <span class="footer-stat-label">CASES</span></span>
        <span class="footer-dot">·</span>
        <span class="footer-stat">{formatBigNumber(totalPwned)} <span class="footer-stat-label">PWNED</span></span>
        <span class="footer-dot">·</span>
        <span class="footer-stat">{criticalCount} <span class="footer-stat-label">CRITICAL</span></span>
      </div>
      <div class="footer-right">
        <div class="footer-links">
          <a href="/about">About</a>
          <a href="/check">Password Check</a>
          <a href="https://haveibeenpwned.com" target="_blank" rel="noopener" aria-label="Have I Been Pwned (opens in new tab)">HIBP ↗</a>
        </div>
        <span class="footer-data">Data: <a href="https://haveibeenpwned.com" target="_blank" rel="noopener">Have I Been Pwned</a> · Troy Hunt</span>
      </div>
    </div>
  </footer>
</BaseLayout>

<script>
  (function () {
    function formatBig(n: number): string {
      if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B'
      if (n >= 1_000_000) return (n / 1_000_000).toFixed(0) + 'M'
      return n.toLocaleString()
    }

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3)
    }

    const DURATION = 1800
    const els = document.querySelectorAll<HTMLElement>('[data-count]')
    if (!els.length) return

    let started = false

    const observer = new IntersectionObserver((entries) => {
      if (started) return
      if (!entries.some((e) => e.isIntersecting)) return
      started = true
      observer.disconnect()

      const start = performance.now()
      function tick(now: number) {
        const t = Math.min((now - start) / DURATION, 1)
        const p = easeOut(t)
        els.forEach((el) => {
          const target = Number(el.dataset.count)
          const isBig = el.dataset.countFormat === 'big'
          const val = Math.floor(target * p)
          el.textContent = isBig ? formatBig(val) : val.toLocaleString()
        })
        if (t < 1) requestAnimationFrame(tick)
      }
      requestAnimationFrame(tick)
    }, { threshold: 0.1 })

    observer.observe(els[0])
  })()
</script>

<style>
  main {
    min-height: 100vh;
  }

  .hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem 4rem;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 18vw, 14rem);
    letter-spacing: 0.12em;
    color: var(--color-text);
    margin: 0;
    line-height: 0.9;
    text-shadow: 0 0 80px rgba(59, 130, 246, 0.15);
    animation: fade-up 0.8s ease both;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: clamp(0.55rem, 1.5vw, 0.75rem);
    letter-spacing: 0.35em;
    color: var(--color-muted);
    margin: 0;
    animation: fade-up 0.8s ease 0.15s both;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    animation: fade-up 0.8s ease 0.3s both;
    padding: 1rem 2rem;
    border: 1px solid var(--color-border);
    background: rgba(13, 17, 23, 0.6);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.6rem;
    color: var(--color-text);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .critical-val { color: var(--color-danger); }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--color-muted);
  }

  .stat-divider {
    font-family: var(--font-mono);
    color: var(--color-border);
    font-size: 1.2rem;
  }

  .hero-cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    animation: fade-up 0.8s ease 0.45s both;
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    font-weight: 600;
    text-decoration: none;
    padding: 10px 24px;
    border: 1px solid var(--color-accent);
    color: #fff;
    background: var(--color-accent);
    transition: all 0.15s;
    border-radius: 2px;
  }

  .hero-cta:hover { background: #2563eb; border-color: #2563eb; }

  .hero-cta-ghost {
    background: transparent;
    color: var(--color-muted);
    border-color: var(--color-border);
  }

  .hero-cta-ghost:hover { color: var(--color-text); border-color: var(--color-muted); background: transparent; }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  .grid-cell {
    border: 1px solid var(--color-text);
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.75rem 2rem;
    background: var(--color-surface);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    color: var(--color-muted);
    opacity: 0.5;
    line-height: 1;
  }

  .footer-tagline {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.25em;
    color: var(--color-muted);
    opacity: 0.35;
  }

  .footer-center {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
  }

  .footer-stat {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    opacity: 0.5;
  }

  .footer-stat-label {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.15em;
    opacity: 0.7;
  }

  .footer-dot {
    color: var(--color-border);
    font-size: 1rem;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
    opacity: 0.6;
  }

  .footer-links a:hover { color: var(--color-text); opacity: 1; }

  .footer-data {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    opacity: 0.4;
  }

  .footer-data a {
    color: var(--color-muted);
    text-decoration: none;
  }

  .footer-data a:hover { color: var(--color-accent); opacity: 1; }

  @media (max-width: 640px) {
    .hero { padding: 4rem 1rem 3rem; }
    .hero-stats { gap: 1rem; padding: 0.75rem 1rem; }
    .stat-divider { display: none; }
    .footer-inner { grid-template-columns: 1fr; gap: 1rem; }
    .footer-right { align-items: flex-start; }
    .footer-center { justify-content: flex-start; }
  }
</style>
