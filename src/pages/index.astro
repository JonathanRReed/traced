---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { HeroTitle } from '../components/HeroTitle'
import { getAllBreaches } from '../lib/hibp'
import { getTotalPwnCount, getAllDataClasses, getBreachStatus } from '../lib/utils'
import { TimelineScrubber } from '../components/TimelineScrubber'
import { BreachArchive } from '../components/BreachArchive'
import FieldBriefing from '../components/FieldBriefing.astro'

const breaches = await getAllBreaches()
const totalPwned = getTotalPwnCount(breaches)
const totalDataClasses = getAllDataClasses(breaches).length
const criticalCount = breaches.filter((b) => getBreachStatus(b) === 'CRITICAL').length

function formatBigNumber(n: number): string {
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B'
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(0) + 'M'
  return n.toLocaleString()
}
---

<BaseLayout title="TRACED — Every Breach. Every Record." description="Browse known data breaches as case files and check whether a password appears in known breach data.">
  <Nav currentPath="/" />

  <main id="main-content" tabindex="-1">
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">Public Breach Archive</div>
        <h1 class="hero-title"><HeroTitle client:load /></h1>
        <p class="hero-tagline">KNOWN BREACHES. ON THE RECORD.</p>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value" data-count={breaches.length}>{breaches.length}</span>
            <span class="stat-label">CASE FILES</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value" data-count={totalPwned} data-count-format="big">{formatBigNumber(totalPwned)}</span>
            <span class="stat-label">EXPOSED ACCOUNTS</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value" data-count={totalDataClasses}>{totalDataClasses}</span>
            <span class="stat-label">DATA TYPES EXPOSED</span>
          </div>
          <div class="stat-divider">·</div>
          <div class="stat">
            <span class="stat-value critical-val" data-count={criticalCount}>{criticalCount}</span>
            <span class="stat-label">CRITICAL</span>
          </div>
        </div>

        <div class="hero-cta-row">
          <a href="#archive" class="hero-cta">BROWSE THE ARCHIVE ↓</a>
          <a href="/check" class="hero-cta hero-cta-ghost">CHECK A PASSWORD →</a>
        </div>
      </div>

      <div class="hero-grid-bg" aria-hidden="true">
        {Array.from({ length: 80 }).map((_, i) => (
          <div class="grid-cell" style={`--i: ${i % 10 + Math.floor(i / 10) * 0.5}`} />
        ))}
      </div>

      <div class="hero-glow" aria-hidden="true"></div>
    </section>

    <FieldBriefing breachCount={breaches.length} criticalCount={criticalCount} />

    <TimelineScrubber client:visible />

    <section id="archive" aria-labelledby="archive-heading">
      <h2 id="archive-heading" class="sr-only">Breach Archive</h2>
      <BreachArchive client:visible />
    </section>
  </main>

  <Footer stats={{ cases: breaches.length, accounts: formatBigNumber(totalPwned), critical: criticalCount }} />
</BaseLayout>

<script>
  (function () {
    function formatBig(n: number): string {
      if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(1) + 'B'
      if (n >= 1_000_000) return (n / 1_000_000).toFixed(0) + 'M'
      return n.toLocaleString()
    }

    function easeOut(t: number): number {
      return 1 - Math.pow(1 - t, 3)
    }

    const DURATION = 1800
    const els = document.querySelectorAll<HTMLElement>('[data-count]')
    if (!els.length) return

    let started = false

    const observer = new IntersectionObserver((entries) => {
      if (started) return
      if (!entries.some((e) => e.isIntersecting)) return
      started = true
      observer.disconnect()

      const start = performance.now()
      function tick(now: number) {
        const t = Math.min((now - start) / DURATION, 1)
        const p = easeOut(t)
        els.forEach((el) => {
          const target = Number(el.dataset.count)
          const isBig = el.dataset.countFormat === 'big'
          const val = Math.floor(target * p)
          el.textContent = isBig ? formatBig(val) : val.toLocaleString()
        })
        if (t < 1) requestAnimationFrame(tick)
      }
      requestAnimationFrame(tick)
    }, { threshold: 0.1 })

    observer.observe(els[0])
  })()
</script>

<style>
  main {
    min-height: 100vh;
  }

  .hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem 4rem;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 18vw, 14rem);
    letter-spacing: 0.12em;
    color: var(--color-text);
    margin: 0;
    line-height: 0.9;
    text-shadow: 0 0 80px rgba(59, 130, 246, 0.15);
    animation: fade-up 0.8s ease both;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: clamp(0.55rem, 1.5vw, 0.75rem);
    letter-spacing: 0.35em;
    color: var(--color-muted);
    margin: 0;
    animation: fade-up 0.8s ease 0.3s both;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    animation: fade-up 0.8s ease 0.6s both;
    padding: 1rem 2rem;
    border: 1px solid var(--color-border);
    background: rgba(13, 17, 23, 0.6);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.6rem;
    color: var(--color-text);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .critical-val { color: var(--color-danger); }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--color-muted);
  }

  .stat-divider {
    font-family: var(--font-mono);
    color: var(--color-border);
    font-size: 1.2rem;
  }

  .hero-cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    animation: fade-up 0.8s ease 0.9s both;
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    font-weight: 600;
    text-decoration: none;
    padding: 10px 24px;
    border: 1px solid var(--color-accent);
    color: #fff;
    background: var(--color-accent);
    transition: all 0.15s;
    border-radius: 2px;
  }

  .hero-cta:hover { background: var(--color-accent-hover); border-color: var(--color-accent-hover); }

  .hero-cta-ghost {
    background: transparent;
    color: var(--color-muted);
    border-color: var(--color-border);
  }

  .hero-cta-ghost:hover { color: var(--color-text); border-color: var(--color-muted); background: transparent; }

  .hero-grid-bg {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  .grid-cell {
    border: 1px solid var(--color-text);
    animation: grid-pulse 4s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 0.08s);
  }

  @keyframes grid-pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
  }

  @media (max-width: 640px) {
    .hero { padding: 4rem 1rem 3rem; }
    .hero-stats { gap: 1rem; padding: 0.75rem 1rem; }
    .stat-divider { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .grid-cell { animation: none; }
  }
</style>
