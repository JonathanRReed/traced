---
interface Props {
  stats?: {
    cases: number
    accounts: string
    critical: number
  }
}
const { stats } = Astro.props
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-wordmark">TRACED</span>
      <span class="footer-tagline">Public Breach Archive</span>
    </div>
    {stats && (
      <div class="footer-center">
        <span class="footer-stat">{stats.cases} <span class="footer-stat-label">CASES</span></span>
        <span class="footer-dot">&middot;</span>
        <span class="footer-stat">{stats.accounts} <span class="footer-stat-label">ACCOUNTS</span></span>
        <span class="footer-dot">&middot;</span>
        <span class="footer-stat">{stats.critical} <span class="footer-stat-label">CRITICAL</span></span>
      </div>
    )}
    <div class="footer-right">
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/check">Password Check</a>
        <a href="https://haveibeenpwned.com" target="_blank" rel="noopener" aria-label="Have I Been Pwned (opens in new tab)">HIBP &#8599;</a>
      </div>
      <span class="footer-data">Source: <a href="https://haveibeenpwned.com" target="_blank" rel="noopener">Have I Been Pwned</a> &middot; Troy Hunt</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.75rem 2rem;
    background: var(--color-surface);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    color: var(--color-muted);
    opacity: 0.5;
    line-height: 1;
  }

  .footer-tagline {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.25em;
    color: var(--color-muted);
    opacity: 0.35;
  }

  .footer-center {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    justify-content: center;
  }

  .footer-stat {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    opacity: 0.5;
  }

  .footer-stat-label {
    font-family: var(--font-mono);
    font-size: 0.48rem;
    letter-spacing: 0.15em;
    opacity: 0.7;
  }

  .footer-dot {
    color: var(--color-border);
    font-size: 1rem;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s, opacity 0.15s;
    opacity: 0.6;
  }

  .footer-links a:hover { color: var(--color-text); opacity: 1; }

  .footer-data {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    opacity: 0.4;
  }

  .footer-data a {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s, opacity 0.15s;
  }

  .footer-data a:hover { color: var(--color-accent); opacity: 1; }

  @media (max-width: 640px) {
    .site-footer { padding: 1.75rem 1rem; }
    .footer-inner { grid-template-columns: 1fr; gap: 1rem; }
    .footer-right { align-items: flex-start; }
    .footer-center { justify-content: flex-start; }
  }
</style>
